# ── Secrets & runtime config ─────────────────────────────────────────────
# 本地配置（含凭证），仅 config.yaml.template 入库
config.yaml
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# ── Runtime state & logs ─────────────────────────────────────────────────
# SessionManager / CronService / ctx 运行时数据
data/
logs/
*.log

# ── Test artifacts ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ── Project 运行数据（ephemeral，每次 E2E 测试产生；真实项目也由 create_project 写） ──
# workspace/ 下其余（manager/pm/rd/qa/shared 模板）需要入库
workspace/shared/projects/

# ── pgvector / db dumps ──────────────────────────────────────────────────
*.sql.gz
*.dump

# ── Python artifacts ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg

# ── Virtualenvs ──────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE / OS ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── MCP / AI agent local state ───────────────────────────────────────────
.claude/
.cursor/

# ── Node (若未来加前端) ───────────────────────────────────────────────────
node_modules/
package-lock.json
